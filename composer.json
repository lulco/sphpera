{
    "name": "lulco/sphpera",
    "require": {
        "php": "^8.4",
        "nikic/php-parser": "^5.0",
        "symfony/console": "^7.0",
        "symfony/finder": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "Sphpera\\": [
                "src/"
            ]
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SphperaTest\\": [
                "tests/"
            ]
        }
    },
    "require-dev": {
        "ext-curl": "*",
        "ext-pdo": "*",
        "phpunit/phpunit": "^11.0",
        "guzzlehttp/guzzle": "^7.0",
        "phpstan/phpstan": "^2.1"
    },
    "bin": ["bin/sphpera"]
}
